# Seul secret réellement requis avant le premier démarrage : le mot de passe
# Postgres (SECRET_KEY/HMAC_KEY sont générés automatiquement, le compte
# administrateur se crée depuis l'écran de démarrage de l'application).
DB_PASSWORD=changez-moi
MOCK_MODE=true

# Version des images Docker à suivre sur le NAS. "latest" (défaut) = suit
# automatiquement chaque push publié (tâche planifiée DSM → nas-update.sh).
# Fixer "vX.Y.Z" ou "sha-abc1234" pour épingler une version précise et
# neutraliser la mise à jour automatique.
MATHPRINT_VERSION=latest
