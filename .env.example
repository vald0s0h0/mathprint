DB_PASSWORD=changez-moi
SECRET_KEY=changez-moi-jwt
HMAC_KEY=changez-moi-hmac
MOCK_MODE=true

# Version des images Docker à suivre sur le NAS. "latest" (défaut) = suit
# automatiquement la dernière release publiée (Watchtower). Fixer "vX.Y.Z"
# pour épingler une version précise et désactiver la mise à jour auto.
MATHPRINT_VERSION=latest
